{
  "name": "four-survivours",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev":     "concurrently -n SERVER,CLIENT -c cyan,yellow \"node server/index.js\" \"vite\"",
    "server":  "node server/index.js",
    "client":  "vite",
    "build":   "vite build",
    "preview": "vite preview",
    "claude": "claude --model sonnet --dangerously-skip-permissions --remote-control"
  },
  "dependencies": {
    "three":            "^0.170.0",
    "socket.io":        "^4.8.1",
    "socket.io-client": "^4.8.1",
    "express":          "^4.21.2"
  },
  "devDependencies": {
    "vite":         "^6.0.0",
    "concurrently": "^9.1.2"
  }
}
